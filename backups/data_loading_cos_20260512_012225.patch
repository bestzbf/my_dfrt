+        max_requeue = max(
+            1,
+            int(os.getenv("D4RT_MAX_REQUEUE", str(max_requeue))),
+        )
+        deadline = time.time() + total_timeout
+        requested = int(index)
+        first_loop = True
+        last_alive_log = 0.0
+
+        while True:
+            remaining = deadline - time.time()
+            if remaining <= 0:
